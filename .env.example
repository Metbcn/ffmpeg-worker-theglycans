# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Security (REQUIRED) ────────────────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
FFMPEG_WORKER_API_KEY=CHANGE_ME_STRONG_RANDOM_KEY

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL where this service is reachable (no trailing slash)
# Example: https://ffmpeg.tu-dominio.com
PUBLIC_BASE_URL=https://ffmpeg.tu-dominio.com

# ── Directories ───────────────────────────────────────────────────────────────
OUTPUT_DIR=/app/output
TEMP_DIR=/app/temp

# ── Cleanup ───────────────────────────────────────────────────────────────────
# Minutes before output files are auto-deleted
# 1440 = 24 hours — recommended for production to give Blotato time to publish
OUTPUT_TTL_MINUTES=1440
